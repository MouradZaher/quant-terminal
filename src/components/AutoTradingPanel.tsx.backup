'use client'

import React, { useState, useEffect } from 'react'

interface TradingBot {
  id: string
  name: string
  strategy: 'SMA Crossover' | 'RSI Strategy' | 'Trend Following' | 'Mean Reversion'
  symbol: string
  status: 'stopped' | 'running' | 'paused' | 'error'
  config: BotConfig
  performance: BotPerformance
  positions: BotPosition[]
  createdAt: number
  startedAt?: number
  lastTradeAt?: number
  errorMessage?: string
}

interface BotConfig {
  maxPositionSize: number
  maxDrawdown: number
  stopLoss: number
  takeProfit: number
  fastPeriod?: number
  slowPeriod?: number
  rsiPeriod?: number
  rsiOverbought?: number
  rsiOversold?: number
  orderSize: number
  maxOrders: number
  cooldownPeriod: number
}

interface BotPerformance {
  totalTrades: number
  winningTrades: number
  losingTrades: number
  totalPnL: number
  winRate: number
  avgTrade: number
  bestTrade: number
  worstTrade: number
  sharpeRatio: number
  maxDrawdown: number
  currentDrawdown: number
}

interface BotPosition {
  symbol: string
  quantity: number
  entryPrice: number
  currentPrice: number
  pnl: number
  pnlPercent: number
  entryTime: number
}

const strategies = [
  { value: 'SMA Crossover', label: 'SMA Crossover', desc: 'Fast/slow moving average crossover' },
  { value: 'RSI Strategy', label: 'RSI Strategy', desc: 'RSI overbought/oversold signals' },
  { value: 'Trend Following', label: 'Trend Following', desc: 'Follow strong market trends' },
  { value: 'Mean Reversion', label: 'Mean Reversion', desc: 'Trade against extreme movements' }
]

export default function AutoTradingPanel() {
  const [bots, setBots] = useState<TradingBot[]>([])
  const [isLoading, setIsLoading] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const [showCreateForm, setShowCreateForm] = useState(false)
  const [selectedBot, setSelectedBot] = useState<TradingBot | null>(null)

  // Create bot form state
  const [botForm, setBotForm] = useState({
    name: '',
    strategy: 'SMA Crossover',
    symbol: 'BTCUSDT',
    config: {
      maxPositionSize: 10,
      maxDrawdown: 5,
      stopLoss: 2,
      takeProfit: 5,
      orderSize: 100,
      maxOrders: 3,
      cooldownPeriod: 5
    }
  })

  // Load bots
  const loadBots = async () => {
    try {
      setIsLoading(true)
      const response = await fetch('/api/bots')
      const data = await response.json()
      setBots(data)
      setError(null)
    } catch (err) {
      setError('Failed to load bots')
      console.error('Load bots error:', err)
    } finally {
      setIsLoading(false)
    }
  }

  // Create bot
  const createBot = async () => {
    if (!botForm.name.trim()) {
      setError('Bot name is required')
      return
    }

    try {
      setIsLoading(true)
      const response = await fetch('/api/bots', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(botForm),
      })

      const result = await response.json()

      if (result.id) {
        setBots(prev => [...prev, result])
        setBotForm({
          name: '',
          strategy: 'SMA Crossover',
          symbol: 'BTCUSDT',
          config: {
            maxPositionSize: 10,
            maxDrawdown: 5,
            stopLoss: 2,
            takeProfit: 5,
            orderSize: 100,
            maxOrders: 3,
            cooldownPeriod: 5
          }
        })
        setShowCreateForm(false)
        setError(null)
      } else {
        setError(result.error || 'Failed to create bot')
      }
    } catch (err) {
      setError('Failed to create bot')
      console.error('Create bot error:', err)
    } finally {
      setIsLoading(false)
    }
  }

  // Control bot (start/stop/pause/resume)
  const controlBot = async (botId: string, action: 'start' | 'stop' | 'pause' | 'resume') => {
    try {
      const response = await fetch(`/api/bots/${botId}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ action }),
      })

      const result = await response.json()

      if (result.id) {
        setBots(prev => prev.map(bot => bot.id === botId ? result : bot))
      } else {
        setError(result.error || `Failed to ${action} bot`)
      }
    } catch (err) {
      setError(`Failed to ${action} bot`)
      console.error('Control bot error:', err)
    }
  }

  // Delete bot
  const deleteBot = async (botId: string) => {
    if (!confirm('Are you sure you want to delete this bot? This action cannot be undone.')) {
      return
    }

    try {
      const response = await fetch(`/api/bots/${botId}`, {
        method: 'DELETE',
      })

      const result = await response.json()

      if (result.success) {
        setBots(prev => prev.filter(bot => bot.id !== botId))
        if (selectedBot?.id === botId) {
          setSelectedBot(null)
        }
      } else {
        setError(result.error || 'Failed to delete bot')
      }
    } catch (err) {
      setError('Failed to delete bot')
      console.error('Delete bot error:', err)
    }
  }

  useEffect(() => {
    loadBots()
    // Refresh bots every 10 seconds
    const interval = setInterval(loadBots, 10000)
    return () => clearInterval(interval)
  }, [])

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'running': return 'text-green-400'
      case 'paused': return 'text-yellow-400'
      case 'stopped': return 'text-gray-400'
      case 'error': return 'text-red-400'
      default: return 'text-gray-400'
    }
  }

  const getStatusIcon = (status: string) => {
    switch (status) {
      case 'running': return '🟢'
      case 'paused': return '🟡'
      case 'stopped': return '⚪'
      case 'error': return '🔴'
      default: return '⚪'
    }
  }

  const formatCurrency = (value: number) => {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }).format(value)
  }

  const formatPercent = (value: number) => {
    return `${value >= 0 ? '+' : ''}${value.toFixed(2)}%`
  }

  return (
    <div className="h-full flex flex-col bg-gray-900 text-gray-100">
      <div className="p-4 border-b border-gray-700">
        <div className="flex justify-between items-center mb-4">
          <h2 className="text-lg font-bold">Auto Trading Bots</h2>
          <div className="flex space-x-2">
            <button
              onClick={loadBots}
              disabled={isLoading}
              className="px-3 py-1 bg-blue-600 hover:bg-blue-700 disabled:bg-gray-600 text-white text-sm rounded"
            >
              {isLoading ? 'Loading...' : 'Refresh'}
            </button>
            <button
              onClick={() => setShowCreateForm(!showCreateForm)}
              className="px-3 py-1 bg-green-600 hover:bg-green-700 text-white text-sm rounded"
            >
              {showCreateForm ? 'Cancel' : '+ New Bot'}
            </button>
          </div>
        </div>

        {error && (
          <div className="bg-red-900 border border-red-700 text-red-200 px-4 py-2 rounded mb-4">
            {error}
          </div>
        )}

        {/* Create Bot Form */}
        {showCreateForm && (
          <div className="bg-gray-800 p-4 rounded-lg mb-4">
            <h3 className="text-md font-bold mb-3">Create New Bot</h3>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div>
                <label className="block text-sm font-medium mb-1">Bot Name</label>
                <input
                  type="text"
                  value={botForm.name}
                  onChange={(e) => setBotForm(prev => ({ ...prev, name: e.target.value }))}
                  placeholder="My Trading Bot"
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Strategy</label>
                <select
                  value={botForm.strategy}
                  onChange={(e) => setBotForm(prev => ({ ...prev, strategy: e.target.value as any }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                >
                  {strategies.map(strategy => (
                    <option key={strategy.value} value={strategy.value}>
                      {strategy.label}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Symbol</label>
                <select
                  value={botForm.symbol}
                  onChange={(e) => setBotForm(prev => ({ ...prev, symbol: e.target.value }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                >
                  <option value="BTCUSDT">BTC/USDT</option>
                  <option value="ETHUSDT">ETH/USDT</option>
                  <option value="SOLUSDT">SOL/USDT</option>
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Max Position Size (%)</label>
                <input
                  type="number"
                  value={botForm.config.maxPositionSize}
                  onChange={(e) => setBotForm(prev => ({
                    ...prev,
                    config: { ...prev.config, maxPositionSize: Number(e.target.value) }
                  }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                  min="1"
                  max="100"
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Stop Loss (%)</label>
                <input
                  type="number"
                  value={botForm.config.stopLoss}
                  onChange={(e) => setBotForm(prev => ({
                    ...prev,
                    config: { ...prev.config, stopLoss: Number(e.target.value) }
                  }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                  min="0.1"
                  step="0.1"
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Take Profit (%)</label>
                <input
                  type="number"
                  value={botForm.config.takeProfit}
                  onChange={(e) => setBotForm(prev => ({
                    ...prev,
                    config: { ...prev.config, takeProfit: Number(e.target.value) }
                  }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                  min="0.1"
                  step="0.1"
                />
              </div>
            </div>

            <div className="mt-4 flex justify-end">
              <button
                onClick={createBot}
                disabled={isLoading}
                className="px-4 py-2 bg-green-600 hover:bg-green-700 disabled:bg-gray-600 text-white text-sm font-medium rounded"
              >
                Create Bot
              </button>
            </div>
          </div>
        )}
      </div>

      {/* Main Content */}
      <div className="flex-1 grid grid-cols-1 lg:grid-cols-3 gap-4 p-4 overflow-auto">
        {/* Bot List */}
        <div className="lg:col-span-2 space-y-4">
          <h3 className="text-md font-bold">Active Bots ({bots.length})</h3>

          {bots.length === 0 ? (
            <div className="bg-gray-800 rounded-lg p-8 text-center text-gray-400">
              No trading bots created yet. Click "New Bot" to get started.
            </div>
          ) : (
            <div className="space-y-3">
              {bots.map((bot) => (
                <div
                  key={bot.id}
                  className={`bg-gray-800 rounded-lg p-4 cursor-pointer border-2 ${
                    selectedBot?.id === bot.id ? 'border-green-500' : 'border-gray-700'
                  }`}
                  onClick={() => setSelectedBot(bot)}
                >
                  <div className="flex justify-between items-start mb-3">
                    <div>
                      <div className="flex items-center space-x-2 mb-1">
                        <span className="font-bold text-lg">{bot.name}</span>
                        <span className={`text-sm ${getStatusColor(bot.status)}`}>
                          {getStatusIcon(bot.status)} {bot.status.toUpperCase()}
                        </span>
                      </div>
                      <div className="text-sm text-gray-400">
                        {bot.strategy} • {bot.symbol}
                      </div>
                    </div>

                    <div className="flex space-x-1">
                      {bot.status === 'stopped' && (
                        <button
                          onClick={(e) => { e.stopPropagation(); controlBot(bot.id, 'start') }}
                          className="px-2 py-1 bg-green-600 hover:bg-green-700 text-white text-xs rounded"
                        >
                          Start
                        </button>
                      )}
                      {bot.status === 'running' && (
                        <>
                          <button
                            onClick={(e) => { e.stopPropagation(); controlBot(bot.id, 'pause') }}
                            className="px-2 py-1 bg-yellow-600 hover:bg-yellow-700 text-white text-xs rounded"
                          >
                            Pause
                          </button>
                          <button
                            onClick={(e) => { e.stopPropagation(); controlBot(bot.id, 'stop') }}
                            className="px-2 py-1 bg-red-600 hover:bg-red-700 text-white text-xs rounded"
                          >
                            Stop
                          </button>
                        </>
                      )}
                      {bot.status === 'paused' && (
                        <button
                          onClick={(e) => { e.stopPropagation(); controlBot(bot.id, 'resume') }}
                          className="px-2 py-1 bg-blue-600 hover:bg-blue-700 text-white text-xs rounded"
                        >
                          Resume
                        </button>
                      )}
                      <button
                        onClick={(e) => { e.stopPropagation(); deleteBot(bot.id) }}
                        className="px-2 py-1 bg-red-600 hover:bg-red-700 text-white text-xs rounded"
                      >
                        Delete
                      </button>
                    </div>
                  </div>

                  {/* Performance Summary */}
                  <div className="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                    <div>
                      <div className="text-gray-400">Total P&L</div>
                      <div className={`font-bold ${bot.performance.totalPnL >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                        {formatCurrency(bot.performance.totalPnL)}
                      </div>
                    </div>

                    <div>
                      <div className="text-gray-400">Win Rate</div>
                      <div className="font-bold text-blue-400">
                        {(bot.performance.winRate * 100).toFixed(1)}%
                      </div>
                    </div>

                    <div>
                      <div className="text-gray-400">Total Trades</div>
                      <div className="font-bold text-purple-400">
                        {bot.performance.totalTrades}
                      </div>
                    </div>

                    <div>
                      <div className="text-gray-400">Max Drawdown</div>
                      <div className="font-bold text-red-400">
                        {bot.performance.maxDrawdown.toFixed(1)}%
                      </div>
                    </div>
                  </div>

                  {bot.startedAt && (
                    <div className="mt-2 text-xs text-gray-400">
                      Started: {new Date(bot.startedAt).toLocaleString()}
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Bot Details Panel */}
        <div className="bg-gray-800 rounded-lg p-4">
          <h3 className="text-md font-bold mb-3">Bot Details</h3>

          {selectedBot ? (
            <div className="space-y-4">
              <div>
                <h4 className="font-bold text-green-400 mb-2">{selectedBot.name}</h4>
                <div className="text-sm text-gray-400 space-y-1">
                  <div>Strategy: {selectedBot.strategy}</div>
                  <div>Symbol: {selectedBot.symbol}</div>
                  <div>Status: <span className={getStatusColor(selectedBot.status)}>{selectedBot.status.toUpperCase()}</span></div>
                  <div>Created: {new Date(selectedBot.createdAt).toLocaleString()}</div>
                </div>
              </div>

              {/* Configuration */}
              <div>
                <h4 className="font-bold mb-2">Risk Management</h4>
                <div className="text-sm space-y-1">
                  <div>Max Position: {selectedBot.config.maxPositionSize}%</div>
                  <div>Stop Loss: {selectedBot.config.stopLoss}%</div>
                  <div>Take Profit: {selectedBot.config.takeProfit}%</div>
                  <div>Max Drawdown: {selectedBot.config.maxDrawdown}%</div>
                </div>
              </div>

              {/* Strategy Parameters */}
              {(selectedBot.strategy === 'SMA Crossover' || selectedBot.strategy === 'RSI Strategy') && (
                <div>
                  <h4 className="font-bold mb-2">Strategy Parameters</h4>
                  <div className="text-sm space-y-1">
                    {selectedBot.strategy === 'SMA Crossover' && (
                      <>
                        <div>Fast Period: {selectedBot.config.fastPeriod}</div>
                        <div>Slow Period: {selectedBot.config.slowPeriod}</div>
                      </>
                    )}
                    {selectedBot.strategy === 'RSI Strategy' && (
                      <>
                        <div>RSI Period: {selectedBot.config.rsiPeriod}</div>
                        <div>Overbought: {selectedBot.config.rsiOverbought}</div>
                        <div>Oversold: {selectedBot.config.rsiOversold}</div>
                      </>
                    )}
                  </div>
                </div>
              )}

              {/* Performance */}
              <div>
                <h4 className="font-bold mb-2">Performance</h4>
                <div className="text-sm space-y-1">
                  <div>Total Trades: {selectedBot.performance.totalTrades}</div>
                  <div>Win Rate: {(selectedBot.performance.winRate * 100).toFixed(1)}%</div>
                  <div>Best Trade: {formatCurrency(selectedBot.performance.bestTrade)}</div>
                  <div>Worst Trade: {formatCurrency(selectedBot.performance.worstTrade)}</div>
                  <div>Sharpe Ratio: {selectedBot.performance.sharpeRatio.toFixed(2)}</div>
                </div>
              </div>

              {/* Positions */}
              {selectedBot.positions.length > 0 && (
                <div>
                  <h4 className="font-bold mb-2">Open Positions</h4>
                  <div className="space-y-2">
                    {selectedBot.positions.map((position, index) => (
                      <div key={index} className="bg-gray-700 p-2 rounded text-sm">
                        <div className="flex justify-between">
                          <span>{position.symbol}</span>
                          <span className={position.pnl >= 0 ? 'text-green-400' : 'text-red-400'}>
                            {formatPercent(position.pnlPercent)}
                          </span>
                        </div>
                        <div className="text-gray-400">
                          Qty: {position.quantity.toFixed(6)} @ {formatCurrency(position.entryPrice)}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ) : (
            <div className="text-gray-400 text-center py-8">
              Select a bot to view details
            </div>
          )}
        </div>
      </div>
    </div>
  )
}

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'running': return 'text-green-400'
      case 'stopped': return 'text-red-400'
      case 'paused': return 'text-yellow-400'
      default: return 'text-gray-400'
    }
  }

  const getStrategyDisplayName = (strategy: string) => {
    switch (strategy) {
      case 'SMA_Crossover': return 'SMA Crossover'
      case 'RSI_Strategy': return 'RSI Strategy'
      default: return strategy
    }
  }

  return (
    <div className="h-full flex flex-col bg-gray-900 text-gray-100">
      <div className="p-4 border-b border-gray-700">
        <div className="flex justify-between items-center mb-4">
          <h2 className="text-lg font-bold">Auto Trading Bots</h2>
          <div className="flex space-x-2">
            <button
              onClick={loadBots}
              disabled={isLoading}
              className="px-3 py-1 bg-blue-600 hover:bg-blue-700 disabled:bg-gray-600 text-white text-sm rounded"
            >
              {isLoading ? 'Loading...' : 'Refresh'}
            </button>
            <button
              onClick={() => setShowCreateForm(!showCreateForm)}
              className="px-3 py-1 bg-green-600 hover:bg-green-700 text-white text-sm rounded"
            >
              {showCreateForm ? 'Cancel' : 'Create Bot'}
            </button>
          </div>
        </div>

        {error && (
          <div className="bg-red-900 border border-red-700 text-red-200 px-4 py-2 rounded mb-4">
            {error}
          </div>
        )}

        {/* Create Bot Form */}
        {showCreateForm && (
          <div className="bg-gray-800 p-4 rounded-lg mb-4">
            <h3 className="text-md font-bold mb-3">Create New Bot</h3>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div>
                <label className="block text-sm font-medium mb-1">Bot Name</label>
                <input
                  type="text"
                  value={newBot.name}
                  onChange={(e) => setNewBot(prev => ({ ...prev, name: e.target.value }))}
                  placeholder="My Trading Bot"
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Strategy</label>
                <select
                  value={newBot.strategy}
                  onChange={(e) => setNewBot(prev => ({ ...prev, strategy: e.target.value as any }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                >
                  <option value="SMA_Crossover">SMA Crossover</option>
                  <option value="RSI_Strategy">RSI Strategy</option>
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Symbol</label>
                <select
                  value={newBot.symbol}
                  onChange={(e) => setNewBot(prev => ({ ...prev, symbol: e.target.value }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                >
                  <option value="BTCUSDT">BTC/USDT</option>
                  <option value="ETHUSDT">ETH/USDT</option>
                  <option value="SOLUSDT">SOL/USDT</option>
                </select>
              </div>

              {/* Strategy-specific parameters */}
              {newBot.strategy === 'SMA_Crossover' && (
                <>
                  <div>
                    <label className="block text-sm font-medium mb-1">Fast SMA Period</label>
                    <input
                      type="number"
                      value={newBot.config.fastPeriod}
                      onChange={(e) => setNewBot(prev => ({
                        ...prev,
                        config: { ...prev.config, fastPeriod: Number(e.target.value) }
                      }))}
                      className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                      min="1"
                    />
                  </div>
                  <div>
                    <label className="block text-sm font-medium mb-1">Slow SMA Period</label>
                    <input
                      type="number"
                      value={newBot.config.slowPeriod}
                      onChange={(e) => setNewBot(prev => ({
                        ...prev,
                        config: { ...prev.config, slowPeriod: Number(e.target.value) }
                      }))}
                      className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                      min="1"
                    />
                  </div>
                </>
              )}

              {newBot.strategy === 'RSI_Strategy' && (
                <>
                  <div>
                    <label className="block text-sm font-medium mb-1">RSI Period</label>
                    <input
                      type="number"
                      value={newBot.config.rsiPeriod}
                      onChange={(e) => setNewBot(prev => ({
                        ...prev,
                        config: { ...prev.config, rsiPeriod: Number(e.target.value) }
                      }))}
                      className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                      min="1"
                    />
                  </div>
                  <div>
                    <label className="block text-sm font-medium mb-1">Overbought</label>
                    <input
                      type="number"
                      value={newBot.config.overbought}
                      onChange={(e) => setNewBot(prev => ({
                        ...prev,
                        config: { ...prev.config, overbought: Number(e.target.value) }
                      }))}
                      className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                      min="1"
                      max="100"
                    />
                  </div>
                  <div>
                    <label className="block text-sm font-medium mb-1">Oversold</label>
                    <input
                      type="number"
                      value={newBot.config.oversold}
                      onChange={(e) => setNewBot(prev => ({
                        ...prev,
                        config: { ...prev.config, oversold: Number(e.target.value) }
                      }))}
                      className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                      min="1"
                      max="100"
                    />
                  </div>
                </>
              )}

              {/* Risk parameters */}
              <div>
                <label className="block text-sm font-medium mb-1">Max Position Size (%)</label>
                <input
                  type="number"
                  value={newBot.config.maxPositionSize * 100}
                  onChange={(e) => setNewBot(prev => ({
                    ...prev,
                    config: { ...prev.config, maxPositionSize: Number(e.target.value) / 100 }
                  }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                  min="1"
                  max="100"
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Stop Loss (%)</label>
                <input
                  type="number"
                  value={newBot.config.stopLoss * 100}
                  onChange={(e) => setNewBot(prev => ({
                    ...prev,
                    config: { ...prev.config, stopLoss: Number(e.target.value) / 100 }
                  }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                  min="0"
                  max="50"
                />
              </div>

              <div>
                <label className="block text-sm font-medium mb-1">Max Orders/Day</label>
                <input
                  type="number"
                  value={newBot.config.maxOrdersPerDay}
                  onChange={(e) => setNewBot(prev => ({
                    ...prev,
                    config: { ...prev.config, maxOrdersPerDay: Number(e.target.value) }
                  }))}
                  className="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm"
                  min="1"
                  max="100"
                />
              </div>
            </div>

            <div className="mt-4">
              <button
                onClick={createBot}
                disabled={isLoading}
                className="px-4 py-2 bg-green-600 hover:bg-green-700 disabled:bg-gray-600 text-white text-sm font-medium rounded"
              >
                Create Bot
              </button>
            </div>
          </div>
        )}
      </div>

      {/* Bots List */}
      <div className="flex-1 p-4 overflow-auto">
        {bots.length === 0 ? (
          <div className="text-center py-8 text-gray-400">
            No trading bots created yet. Click "Create Bot" to get started.
          </div>
        ) : (
          <div className="space-y-4">
            {bots.map((bot) => (
              <div key={bot.id} className="bg-gray-800 rounded-lg p-4">
                <div className="flex justify-between items-start mb-3">
                  <div>
                    <h3 className="text-lg font-bold">{bot.name}</h3>
                    <p className="text-sm text-gray-400">
                      {getStrategyDisplayName(bot.strategy)} • {bot.symbol}
                    </p>
                  </div>
                  <div className="flex items-center space-x-2">
                    <span className={`text-sm font-bold ${getStatusColor(bot.status)}`}>
                      {bot.status.toUpperCase()}
                    </span>
                    <div className="flex space-x-1">
                      {bot.status === 'stopped' ? (
                        <button
                          onClick={() => controlBot(bot.id, 'start')}
                          className="px-2 py-1 bg-green-600 hover:bg-green-700 text-white text-xs rounded"
                        >
                          Start
                        </button>
                      ) : (
                        <button
                          onClick={() => controlBot(bot.id, 'stop')}
                          className="px-2 py-1 bg-red-600 hover:bg-red-700 text-white text-xs rounded"
                        >
                          Stop
                        </button>
                      )}
                      <button
                        onClick={() => controlBot(bot.id, 'delete')}
                        className="px-2 py-1 bg-red-800 hover:bg-red-900 text-white text-xs rounded"
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                </div>

                {/* Performance Metrics */}
                <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-3">
                  <div className="bg-gray-700 p-2 rounded">
                    <div className="text-xs text-gray-400">Total P&L</div>
                    <div className={`text-sm font-bold ${bot.performance.totalPnL >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                      {formatCurrency(bot.performance.totalPnL)}
                    </div>
                  </div>

                  <div className="bg-gray-700 p-2 rounded">
                    <div className="text-xs text-gray-400">Win Rate</div>
                    <div className="text-sm font-bold text-blue-400">
                      {(bot.performance.winRate * 100).toFixed(1)}%
                    </div>
                  </div>

                  <div className="bg-gray-700 p-2 rounded">
                    <div className="text-xs text-gray-400">Total Trades</div>
                    <div className="text-sm font-bold text-purple-400">
                      {bot.performance.totalTrades}
                    </div>
                  </div>

                  <div className="bg-gray-700 p-2 rounded">
                    <div className="text-xs text-gray-400">Balance</div>
                    <div className="text-sm font-bold text-green-400">
                      {formatCurrency(bot.performance.currentBalance)}
                    </div>
                  </div>
                </div>

                {/* Bot Details */}
                <div className="text-xs text-gray-400">
                  Created: {new Date(bot.createdAt).toLocaleString()} •
                  Last Activity: {new Date(bot.lastActivity).toLocaleString()}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}